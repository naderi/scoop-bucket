    "pre_install": [
        "Expand-7zipArchive \"$dir\\updater.7z\" -ExtractDir \"$dir\\updater\"",
        "$mini = Get-ChildItem \"$dir\\updater\\bin\\Offline\" -Recurse -Filter mini_installer.exe | Select-Object -First 1",
        "if (-not $mini) { throw 'mini_installer.exe not found' }",
        "Expand-7zipArchive $mini.FullName -ExtractDir \"$dir\\mini\"",
        "Expand-7zipArchive \"$dir\\mini\\chrome.7z\" -ExtractDir 'Chrome-bin' -DestinationPath \"$dir\" -Removal",
        "Remove-Item \"$dir\\chrome.exe\" -Force -ErrorAction SilentlyContinue"
    ],
    "post_install": "Remove-Item \"$dir\\updater\",\"$dir\\mini\" -Recurse -Force -ErrorAction SilentlyContinue",
    "bin": [
        [
            "comet.exe",
            "comet",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "shortcuts": [
        [
            "comet.exe",
            "Comet",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
